{
  "name": "@emarketeer/ts-microservice-commons",
  "version": "0.0.0",
  "description": "",
  "keywords": [],
  "bin": {
    "em-commons": "./dist/lib/em-commons.js"
  },
  "typings": "dist/types/ts-microservice-commons.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    "./cdk": {
      "import": "./dist/cdk/index.js",
      "require": "./dist/cdk/cjs/index.js",
      "types": "./dist/types/cdk/index.d.ts"
    },
    "./cdk/jest.config": "./dist/cdk/jest.config.js",
    "./cdk/tsconfig.json": "./dist/cdk/tsconfig.json",
    "./cdk/.eslintrc": "./dist/cdk/.eslintrc",
    "./jest.config": "./dist/lib/jest.config.js",
    "./dist/lib/jest.config.js": "./dist/lib/jest.config.js",
    "./.eslintrc": "./dist/.eslintrc",
    "./tsconfig.json": "./dist/tsconfig.json",
    "./esbuild-plugins": "./dist/esbuild-plugins.js",
    "./build-handlers": "./dist/build-handlers.js",
    "./dist/lib/*": "./dist/lib/*",
    "./dist/cdk/*": "./dist/cdk/*",
    "./dist/*": "./dist/*",
    "./*": "./*"
  },
  "peerDependencies": {
    "@recap.dev/client": "^4.3.0",
    "aws-cdk-lib": "^2.0.0",
    "constructs": "^10.0.0"
  },
  "author": "eMarketeer AB <dev@emarketeer.com>",
  "repository": {
    "type": "git",
    "url": ""
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "tslint  --project tsconfig.json -t codeFrame 'src/**/*.ts' 'test/**/*.ts'",
    "prebuild": "rimraf dist",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 rollup -c rollup.config.ts",
    "start": "NODE_OPTIONS=--max-old-space-size=4096 rollup -c rollup.config.ts -w",
    "test": "jest --coverage --passWithNoTests",
    "test:watch": "jest --coverage --watch",
    "test:prod": "npm run lint && npm run test -- --no-cache",
    "deploy-docs": "ts-node tools/gh-pages-publish",
    "commit": "git-cz",
    "semantic-release": "semantic-release",
    "semantic-release-prepare": "ts-node tools/semantic-release-prepare",
    "precommit": "lint-staged",
    "test:cdk": "jest --config jest.cdk.config.ts"
  },
  "lint-staged": {
    "{src,test}/**/*.ts": [
      "prettier --write",
      "git add"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  },
  "jest": {
    "transform": {
      ".(ts|tsx)": "ts-jest"
    },
    "testEnvironment": "node",
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx|js)$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/src/cdk/__tests__/"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/",
      "src/build-handlers.ts",
      "src/em-commons.ts",
      "src/esbuild-plugins.js",
      "src/jest.config.ts",
      "src/webpack.config.ts",
      "src/utils.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 95,
        "lines": 95,
        "statements": 95
      }
    },
    "collectCoverageFrom": [
      "src/*.{js,ts}"
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@emarketeer/esbuild-plugin-tsc": "^0.4.1",
    "@types/jest": "^29.5.1",
    "@typescript-eslint/eslint-plugin": "^5.36.2",
    "@typescript-eslint/parser": "^5.36.2",
    "cross-env": "^6.0.0",
    "cross-spawn": "^7.0.1",
    "esbuild": "^0.25.2",
    "eslint": "7.32.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-sonarjs": "^0.11.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "jest-extended": "^3.2.4",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "@robmarr/rollup-plugin-shebang": "^1.0.1",
    "@rollup/plugin-commonjs": "^15.1.0",
    "@rollup/plugin-node-resolve": "^9.0.0",
    "@types/cross-spawn": "^6.0.1",
    "@types/node": "^20.0.0",
    "aws-cdk-lib": "^2.0.0",
    "colors": "^1.3.2",
    "commitizen": "^4.0.0",
    "constructs": "^10.0.0",
    "cz-conventional-changelog": "^3.0.0",
    "husky": "^9.0.0",
    "jest-config": "^29.5.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.0",
    "rollup": "^2.29.0",
    "rollup-plugin-copy": "^3.1.0",
    "rollup-plugin-executable": "^1.5.2",
    "rollup-plugin-json": "^3.1.0",
    "rollup-plugin-sourcemaps": "^0.4.2",
    "rollup-plugin-typescript2": "^0.27.3",
    "semantic-release": "^24.1.0",
    "shelljs": "^0.8.5",
    "ts-node": "^10.9.2"
  },
  "resolutions": {
    "@types/estree": "0.0.47"
  }
}
